    "bantcredit:fix:legacy-referral-bonuses": "tsx scripts/fix-legacy-referral-bonuses.ts",
    "onchain:deploy:token": "hardhat run scripts/deploy-test-token.ts",
    "onchain:deploy:all": "powershell -ExecutionPolicy Bypass -File scripts/deploy-escrow-all.ps1",
    "onchain:deploy:v2:all": "powershell -ExecutionPolicy Bypass -File scripts/deploy-escrow-v2-all.ps1",
    "onchain:deploy:v2:all-mainnets": "powershell -ExecutionPolicy Bypass -File scripts/deploy-escrow-v2-mainnets.ps1"
