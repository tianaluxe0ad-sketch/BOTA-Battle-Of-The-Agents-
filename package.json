    "onchain:deploy:sim-rewards:bsc": "hardhat run scripts/deploy-sim-rewards.ts --network bscTestnet",
    "onchain:deploy:sim-rewards:arb": "hardhat run scripts/deploy-sim-rewards.ts --network arbitrumSepolia",
    "onchain:deploy:sim-rewards:celo": "hardhat run scripts/deploy-sim-rewards.ts --network celoSepolia",
    "onchain:deploy:sim-rewards:unichain": "hardhat run scripts/deploy-sim-rewards.ts --network unichainSepolia",
    "onchain:deploy:sim-rewards:base-mainnet": "hardhat run scripts/deploy-sim-rewards.ts --network base",
