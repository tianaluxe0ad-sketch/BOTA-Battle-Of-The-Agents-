    "onchain:deploy:launcher-factory:base-sepolia": "hardhat run scripts/deploy-token-factory.ts --network baseSepolia",
    "onchain:deploy:launcher-factory:arb": "hardhat run scripts/deploy-token-factory.ts --network arbitrum",
    "onchain:deploy:launcher-factory:arb-sepolia": "hardhat run scripts/deploy-token-factory.ts --network arbitrumSepolia",
