    "onchain:update:v2:fee:bsc-mainnet": "hardhat run scripts/update-escrow-v2-fee.ts --network bsc",
    "onchain:update:v2:fee:arb-mainnet": "hardhat run scripts/update-escrow-v2-fee.ts --network arbitrum",
    "onchain:update:v2:fee:unichain-mainnet": "hardhat run scripts/update-escrow-v2-fee.ts --network unichain",
