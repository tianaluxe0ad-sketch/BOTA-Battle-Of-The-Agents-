    "onchain:deploy:v2:celo-alfajores": "hardhat run scripts/deploy-escrow-v2.ts --network celoAlfajores",
    "onchain:deploy:v2:unichain": "hardhat run scripts/deploy-escrow-v2.ts --network unichainSepolia",
    "onchain:deploy:v2:base-mainnet": "hardhat run scripts/deploy-escrow-v2.ts --network base",
    "onchain:deploy:v2:bsc-mainnet": "hardhat run scripts/deploy-escrow-v2.ts --network bsc",
    "onchain:deploy:v2:arb-mainnet": "hardhat run scripts/deploy-escrow-v2.ts --network arbitrum",
