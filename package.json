{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist --external:./vite",
    "build:vercel": "vite build && node scripts/build-vercel-server.mjs && node vercel-build.mjs",
    "vercel:build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 npx vercel build --prod && node vercel-bundle-output.mjs",
    "vercel:deploy": "npm run vercel:build && npx vercel deploy --prebuilt --prod --yes",
    "start": "NODE_ENV=production node dist/index.js",
    "heroku-postbuild": "npm run build",
    "check": "tsc",
    "agent:smoke": "tsx scripts/agent-runtime-probe.ts",
    "db:push": "drizzle-kit push",
    "test:e2e": "playwright test",
    "onchain:compile": "hardhat compile",
    "onchain:deploy:base": "hardhat run scripts/deploy-escrow.ts --network baseSepolia",
    "onchain:deploy:bsc": "hardhat run scripts/deploy-escrow.ts --network bscTestnet",
    "onchain:deploy:arb": "hardhat run scripts/deploy-escrow.ts --network arbitrumSepolia",
    "onchain:deploy:celo": "hardhat run scripts/deploy-escrow.ts --network celoSepolia",
    "onchain:deploy:celo-alfajores": "hardhat run scripts/deploy-escrow.ts --network celoAlfajores",
    "onchain:deploy:unichain": "hardhat run scripts/deploy-escrow.ts --network unichainSepolia",
    "onchain:deploy:v2:base": "hardhat run scripts/deploy-escrow-v2.ts --network baseSepolia",
    "onchain:deploy:v2:bsc": "hardhat run scripts/deploy-escrow-v2.ts --network bscTestnet",
    "onchain:deploy:v2:arb": "hardhat run scripts/deploy-escrow-v2.ts --network arbitrumSepolia",
